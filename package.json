{
  "name": "gclm-code",
  "version": "1.0.4",
  "description": "Gclm Code - an AI-powered CLI coding assistant that understands your codebase, edits files, runs terminal commands, and handles entire workflows for you.",
  "type": "module",
  "bin": {
    "gc": "bin/gc.js",
    "claude": "bin/gc.js"
  },
  "homepage": "https://github.com/gclm/gclm-code",
  "bugs": {
    "url": "https://github.com/gclm/gclm-code/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "brand:guard": "bash scripts/brand-guard.sh",
    "verify": "bun run build && bun run smoke",
    "clean": "node ./scripts/clean.mjs",
    "build": "bun scripts/build.mjs",
    "build:dev": "bun scripts/build.mjs --dev",
    "build:dev:full": "bun scripts/build.mjs --dev --feature-set=dev-full",
    "compile": "bun scripts/build.mjs --compile",
    "dev": "bun --preload ./scripts/dev-preload.mjs ./src/entrypoints/cli.tsx",
    "dev:gclm-code-server": "node ./scripts/dev-gclm-code-server.mjs",
    "smoke:gclm-code-server": "bun ./scripts/smoke-gclm-code-server.mjs",
    "smoke:feishu-openapi": "node ./scripts/smoke-feishu-openapi.mjs",
    "smoke:feishu-long-connection": "node ./scripts/smoke-feishu-long-connection.mjs",
    "dev:watch": "bun scripts/dev.mjs --watch-only",
    "smoke:login-gateway": "bun scripts/smoke-login-gateway.mjs",
    "smoke:login-gateway:matrix": "bun scripts/smoke-login-gateway-matrix.mjs",
    "test": "bun test --preload ./tests/preload.ts tests/",
    "test:watch": "bun test --watch --preload ./tests/preload.ts tests/",
    "test:coverage": "bun test --coverage --preload ./tests/preload.ts tests/",
    "smoke": "bun scripts/smoke-test.mjs",
    "pack:npm": "node scripts/pack-npm.mjs",
    "smoke:npm": "node scripts/smoke-npm-package.mjs",
    "release:npm": "bun run build && bun run pack:npm && bun run smoke:npm",
    "prepublishOnly": "node -e \"if (!process.env.AUTHORIZED) { console.error('ERROR: Direct publishing is not allowed.\\nPlease see the release workflow documentation to publish this package.'); process.exit(1); }\""
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@ant/claude-for-chrome-mcp": "workspace:*",
    "@ant/computer-use-input": "workspace:*",
    "@ant/computer-use-mcp": "workspace:*",
    "@ant/computer-use-swift": "workspace:*",
    "@anthropic-ai/bedrock-sdk": "^0.26.4",
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "@anthropic-ai/foundry-sdk": "^0.2.3",
    "@anthropic-ai/mcpb": "^2.1.2",
    "@anthropic-ai/sandbox-runtime": "^0.0.44",
    "@anthropic-ai/sdk": "^0.80.0",
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@aws-sdk/client-bedrock": "^3.1020.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1020.0",
    "@aws-sdk/client-sts": "^3.1020.0",
    "@aws-sdk/credential-provider-node": "^3.972.28",
    "@aws-sdk/credential-providers": "^3.1020.0",
    "@azure/identity": "^4.13.1",
    "@commander-js/extra-typings": "^14.0.0",
    "@growthbook/growthbook": "^1.6.5",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-prometheus": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@smithy/core": "^3.23.13",
    "@smithy/node-http-handler": "^4.5.1",
    "ajv": "^8.18.0",
    "asciichart": "^1.5.25",
    "audio-capture-napi": "workspace:*",
    "auto-bind": "^5.0.1",
    "axios": "^1.14.0",
